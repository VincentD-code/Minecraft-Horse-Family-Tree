</style>

<div id="binder-container">
    <div class="tab-stack">
        <div class="binder-tab active-tab" onclick="openTab(0)" title="Leaderboard">🏆</div>
        <div class="binder-tab" onclick="openTab(1)" title="Generation Stats">📈</div>
