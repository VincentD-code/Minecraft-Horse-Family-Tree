    <div id="mode-text" style="color:#00F5FF; font-weight:bold; font-size:16px;">ANCESTORS</div>
    <div style="margin-top:5px; font-size:9px; color:#666;">CLICK TO TOGGLE | PRESS 'M'</div>
</div>
"""

js_script = f"""
{ui_html}
<script>
var ancestorMap = {anc_json};
var descendantMap = {desc_json};
var stats = {stats_json};
var currentMode = 'ancestors'; 
var currentHighlighted = null;

function openTab(index) {{
    document.getElementById('binder-container').classList.add('active');
    document.querySelectorAll('.binder-page').forEach(p => p.classList.remove('active-page'));
    document.querySelectorAll('.binder-tab').forEach(t => t.classList.remove('active-tab'));
    document.getElementById('page-' + index).classList.add('active-page');
    document.querySelectorAll('.binder-tab')[index].classList.add('active-tab');
}}

window.addEventListener('load', function() {{
    var graphDiv = document.getElementsByClassName('plotly-graph-div')[0];

    // 1. Populate Leaderboard
    const t16Body = document.getElementById('top-16-body');
    stats.top_16.forEach((h, i) => {{
        t16Body.innerHTML += `<tr><td>#${{i+1}}</td><td>${{h.Name}}</td><td style="color:#FFD700; font-weight:bold;">${{h.Speed}}</td></tr>`;
    }});

    // 2. Populate Gen Averages
    const genCont = document.getElementById('gen-stats-container');
    const maxSpeedAcrossGens = Math.max(...Object.values(stats.avg_speed));
    Object.entries(stats.avg_speed).forEach(([gen, spd]) => {{
        let barWidth = (spd / maxSpeedAcrossGens) * 100;
        genCont.innerHTML += `
            <div class="stat-section">
                <div class="stat-label"><span>Generation ${{gen}}</span><span>Avg: ${{spd}}</span></div>
                <div class="bar-bg"><div class="bar-fill" style="width:${{barWidth}}%"></div></div>
            </div>`;
    }});

    // 3. Populate Bloodlines
    const renderBlood = (data, containerId) => {{
        const cont = document.getElementById(containerId);
        Object.entries(data).forEach(([name, val]) => {{
            cont.innerHTML += `
                <div class="stat-section">
                    <div class="stat-label"><span>${{name}}</span><span>${{val}}%</span></div>
                    <div class="bar-bg"><div class="bar-fill gold" style="width:${{val}}%"></div></div>
                </div>`;
        }});
    }};
    renderBlood(stats.blood_alive, 'blood-alive-container');
    renderBlood(stats.blood_all, 'blood-all-container');

    // --- INTEGRATED INTERACTION LOGIC ---
    function toggleMode() {{
        currentMode = (currentMode === 'ancestors') ? 'descendants' : 'ancestors';
        var textEl = document.getElementById('mode-text');
        textEl.innerText = currentMode.toUpperCase();
        textEl.style.color = (currentMode === 'ancestors') ? '#00F5FF' : '#FF4500';
        if (currentHighlighted) highlightLogic(currentHighlighted);
    }}

    document.getElementById('mode-ui').onclick = toggleMode;
    document.addEventListener('keydown', (e) => {{ if(e.key.toLowerCase() === 'm') toggleMode(); }});

    function highlightLogic(selectedHorse) {{
        var targetMap = (currentMode === 'ancestors') ? ancestorMap : descendantMap;
        var relatedSet = targetMap[selectedHorse] || [selectedHorse];
        var newOpacities = []; var newWidths = [];

        for(var i=0; i < graphDiv.data.length; i++){{
            var trace = graphDiv.data[i];
            var rawData = Array.isArray(trace.customdata) ? trace.customdata[0] : trace.customdata;
            var traceHorseName = (rawData && typeof rawData === 'object') ? rawData.child : rawData;

            var isRelated = false;
            if (trace.name === "node" || trace.name === "glow") {{
                isRelated = relatedSet.includes(traceHorseName);
            }} else if (trace.name.includes("line")) {{
                isRelated = relatedSet.includes(traceHorseName) && (traceHorseName !== selectedHorse || currentMode === 'ancestors');
            }}
            newOpacities.push(isRelated ? 1.0 : 0.05);
            newWidths.push(isRelated && trace.name.includes("line") ? 5.0 : (trace.name.includes("line") ? 0.1 : null));
        }}
        Plotly.restyle(graphDiv, {{ 'opacity': newOpacities, 'line.width': newWidths }});
    }}

    graphDiv.on('plotly_click', function(data){{
        if (!data || !data.points) return;
        var pt = data.points[0];
        var rawPointData = pt.customdata;
        var selectedHorse = (rawPointData && typeof rawPointData === 'object') ? (rawPointData.child || rawPointData[0]) : (Array.isArray(rawPointData) ? rawPointData[0] : rawPointData);
        if (!selectedHorse) return;

        if (currentHighlighted === selectedHorse) {{
            // Reset to default
            Plotly.restyle(graphDiv, {{ 'opacity': graphDiv.data.map(t => t.name === "line_parent" ? 0.3 : (t.name === "line_child" ? 0.45 : (t.name === "glow" ? 0.2 : 1.0))), 'line.width': graphDiv.data.map(t => t.name === "line_child" ? 2.5 : (t.name === "line_parent" ? 1.5 : null)) }});
            currentHighlighted = null;
        }} else {{
            currentHighlighted = selectedHorse;
            highlightLogic(selectedHorse);
        }}
    }});

    graphDiv.on('plotly_doubleclick', () => {{
         Plotly.restyle(graphDiv, {{ 'opacity': graphDiv.data.map(t => t.name === "line_parent" ? 0.3 : (t.name === "line_child" ? 0.45 : (t.name === "glow" ? 0.2 : 1.0))), 'line.width': graphDiv.data.map(t => t.name === "line_child" ? 2.5 : (t.name === "line_parent" ? 1.5 : null)) }});
         currentHighlighted = null;
    }});
}});
</script>
"""

with open("index.html", "w", encoding="utf-8") as f:
    f.write(html_content.replace('</body>', js_script + '</body>'))