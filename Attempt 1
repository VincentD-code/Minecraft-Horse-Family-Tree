function resetToDefault() {{
    var graphDiv = document.getElementsByClassName('plotly-graph-div')[0];
    var newOpacities = [];
    var newWidths = [];

    for (var i = 0; i < graphDiv.data.length; i++) {{
        var t = graphDiv.data[i];
        if (t.name === "line_parent") {{
            newOpacities.push(0.30);
            newWidths.push(1.5);
