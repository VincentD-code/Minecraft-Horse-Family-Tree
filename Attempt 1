window.addEventListener('load', function() {{
    var graphDiv = document.getElementsByClassName('plotly-graph-div')[0];

    ['speed', 'jump', 'health'].forEach(stat => {{
        const tbody = document.getElementById(`top-16-${{stat}}-body`);
        const statKey = stat.charAt(0).toUpperCase() + stat.slice(1);
        stats[`top_16_${{stat}}`].forEach((h, i) => {{
            let row = document.createElement('tr');
            row.innerHTML = `<td>${{i+1}}</td><td>${{h.Name}}</td><td style="color:#FFD700; font-weight:bold;">${{h[statKey]}}</td>`;
            row.onclick = () => {{ currentHighlighted = h.Name; highlightLogic(h.Name); }};
            tbody.appendChild(row);
        }});
    }});

    window.switchTable = function(stat) {{
        ['speed', 'jump', 'health'].forEach(s => {{
            document.getElementById(`table-${{s}}`).style.display = (s === stat) ? 'table' : 'none';
            document.getElementById(`tab-${{s}}`).style.color = (s === stat) ? '#FFD700' : '#666';
        }});
    }};

    renderGenChart();

    const renderPie = (targetId, dataDict) => {{
        const labels = Object.keys(dataDict);
        const values = Object.values(dataDict);
        const colors = labels.map(l => bloodColors[l] || "#444444");
        const data = [{{
            values: values, labels: labels, type: 'pie', hole: 0.4,
            marker: {{ colors: colors, line: {{ color: '#121212', width: 2 }} }},
            textinfo: 'percent', hoverinfo: 'label+percent', textfont: {{ family: 'monospace', color: '#fff' }}
        }}];
        const layout = {{
            showlegend: true, legend: {{ orientation: 'h', font: {{ size: 10, color: '#888' }}, y: -0.2 }},
            margin: {{ t: 10, b: 10, l: 10, r: 10 }}, paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)'
        }};
        Plotly.newPlot(targetId, data, layout, {{displayModeBar: false}});
    }};

    renderPie('pie-alive', stats.blood_alive);
    renderPie('pie-all', stats.blood_all);

    window.highlightLogic = function(selectedHorse) {{
        var targetMap = (currentMode === 'ancestors') ? ancestorMap : descendantMap;
        var relatedSet = targetMap[selectedHorse] || [selectedHorse];
        var newOpacities = []; var newWidths = [];

        for(var i=0; i < graphDiv.data.length; i++){{
            var trace = graphDiv.data[i];
            var rawData = Array.isArray(trace.customdata) ? trace.customdata[0] : trace.customdata;
            var traceHorseName = (rawData && typeof rawData === 'object') ? rawData.child : rawData;
            var isRelated = false;
            
            if (trace.name === "node" || trace.name.startsWith("glow")) {{
                isRelated = relatedSet.includes(traceHorseName);
            }} else if (trace.name.includes("line")) {{
                isRelated = relatedSet.includes(traceHorseName) && (traceHorseName !== selectedHorse || currentMode === 'ancestors');
            }}
            newOpacities.push(isRelated ? 1.0 : 0.05);
            newWidths.push(isRelated && trace.name.includes("line") ? 5.0 : (trace.name.includes("line") ? 0.1 : null));
        }}
        Plotly.restyle(graphDiv, {{ 'opacity': newOpacities, 'line.width': newWidths }});
    }};

    window.toggleMode = function() {{
        currentMode = (currentMode === 'ancestors') ? 'descendants' : 'ancestors';
        var txt = document.getElementById('mode-text');
        txt.innerText = currentMode.toUpperCase();
        txt.style.color = (currentMode === 'ancestors') ? '#00F5FF' : '#FF4500';
        if (currentHighlighted && !currentHighlighted.startsWith("gen_")) highlightLogic(currentHighlighted);
    }};

    window.toggleStatMode = function() {{
        if (currentStatMode === 'speed') currentStatMode = 'jump';
        else if (currentStatMode === 'jump') currentStatMode = 'health';
        else currentStatMode = 'speed';

        var txt = document.getElementById('stat-text');
        txt.innerText = "STAT: " + currentStatMode.toUpperCase();
        var statColors = {{ 'speed': '#FFD700', 'jump': '#00FF7F', 'health': '#FF004F' }};
        txt.style.color = statColors[currentStatMode];
        applyStatView();
    }};

    function applyStatView() {{
        var topList = top3Ranks[currentStatMode];
        var nodeIndices = []; var textUpdates = []; var symbolUpdates = [];
        var sizeUpdates = []; var lineWidthUpdates = []; var lineColorUpdates = [];
        var visibleUpdates = []; var glowIndices = [];

        for (var i = 0; i < graphDiv.data.length; i++) {{
            var trace = graphDiv.data[i];
            var tName = trace.name;
            if (tName && tName.startsWith("glow_")) {{
                glowIndices.push(i);
                visibleUpdates.push(tName === "glow_" + currentStatMode);
            }}
            else if (tName === "node") {{
                var rawData = Array.isArray(trace.customdata) ? trace.customdata[0] : trace.customdata;
                var hName = (rawData && typeof rawData === 'object') ? rawData.child : rawData;
                var rank = topList.indexOf(hName);
                var symbol = (rank === 0) ? "star" : (rank === 1 ? "diamond" : (rank === 2 ? "triangle-up" : "circle"));
                var dName = (rank === 0) ? ("★ GOD HORSE: " + hName.toUpperCase() + " ★") : hName.toUpperCase();
                
                nodeIndices.push(i);
                textUpdates.push([dName]);
                symbolUpdates.push(symbol);
                sizeUpdates.push((rank !== -1) ? 26 : 14);
                lineWidthUpdates.push((rank !== -1) ? 4 : 1.5);
                lineColorUpdates.push((rank !== -1) ? (rank === 0 ? "#FFD700" : (rank === 1 ? "#C0C0C0" : "#CD7F32")) : baseColors[hName]);
            }}
        }}
        if (glowIndices.length > 0) Plotly.restyle(graphDiv, {{ 'visible': visibleUpdates }}, glowIndices);
        if (nodeIndices.length > 0) {{
            Plotly.restyle(graphDiv, {{
                'text': textUpdates, 'marker.symbol': symbolUpdates, 'marker.size': sizeUpdates,
                'marker.line.width': lineWidthUpdates, 'marker.line.color': lineColorUpdates
            }}, nodeIndices);
        }}
    }}

    document.addEventListener('keydown', (e) => {{ 
        if(e.key.toLowerCase() === 'm') toggleMode(); 
        if(e.key.toLowerCase() === 's') toggleStatMode();
    }});

    graphDiv.on('plotly_click', function(data){{
        if (!data || !data.points) return;
        var pt = data.points[0]; var raw = pt.customdata;
        var name = (raw && typeof raw === 'object') ? (raw.child || raw[0]) : (Array.isArray(raw) ? raw[0] : raw);
        if (!name) {{ resetToDefault(); return; }}
        if (currentHighlighted === name) resetToDefault();
        else {{ currentHighlighted = name; highlightLogic(name); }}
    }});

    graphDiv.on('plotly_doubleclick', resetToDefault);
    graphDiv.addEventListener('click', (e) => {{ 
        if(e.target.classList.contains('nsewdrag') || e.target.classList.contains('bg')) resetToDefault(); 
    }});
}});
