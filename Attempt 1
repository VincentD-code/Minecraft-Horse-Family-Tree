    .stat-section {{ margin-bottom: 25px; }}
    .stat-label {{ font-size: 12px; display: flex; justify-content: space-between; margin-bottom: 5px; }}
    .bar-bg {{ background: #333; height: 10px; border-radius: 5px; overflow: hidden; }}
